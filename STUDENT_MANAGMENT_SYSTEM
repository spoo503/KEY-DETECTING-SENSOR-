class Student:
    def __init__(self,**kwargs):
        self.name=kwargs.get('name')
        self.roll_no=kwargs.get('roll_no')
        self.stu_class=kwargs.get('stu_class')
    def display(self):
        print("Name of the student",self.name)
        print("Roll_number of the student",self.roll_no)
        print("Class of the student",self.stu_class)
class personal_info(Student):
    def __init__(self,**kwargs):
        super().__init__(**kwargs)
       self.address=kwargs.get('address')
        self.city=kwargs.get('city')
        self.district=kwargs.get('district')
        self.pincode=kwargs.get('pincode')
        self.mobile=kwargs.get('mobile')
        self.mother_name=kwargs.get('mother_name')
        self.mobile_no=kwargs.get('mobile_no')
        self.father_name=kwargs.get('father_name')
        self.mobile_2=kwargs.get('mobile_2')
